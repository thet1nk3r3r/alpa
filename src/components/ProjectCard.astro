---
const { title, description, stack, date, status, link } = Astro.props;
---
<div class="mb-12">
  <h3 class="text-base font-medium">
    {link ? (
      <a
        href={link}
        target="_blank"
        class="underline underline-offset-4 hover:text-black dark:hover:text-white"
      >
        {title}
      </a>
    ) : (
      title
    )}
  </h3>
  {(stack || date || status) && (
    <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
      {stack}
      {stack && date && " · "}
      {date}
      {status === "Ongoing" && (
        <span class="ml-2 text-xs text-emerald-600 dark:text-emerald-400">
          • Active
        </span>
      )}
    </p>
  )}
  <p class="mt-3 text-neutral-600 dark:text-neutral-400 leading-relaxed">
    {description}
  </p>

</div>