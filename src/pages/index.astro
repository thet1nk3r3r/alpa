---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <Fragment slot="title">Home</Fragment>

  <section>
    <h2 class="text-lg font-medium">
      Backend Engineer · Infrastructure Builder · Open Source Contributor
    </h2>

    <p class="mt-4 text-muted leading-relaxed">
      Building scalable backend systems and developer tooling with a focus on
      clarity, reliability, and long term maintainability. Actively contributing
      to open source and infrastructure level improvements.
    </p>
  </section>

  <section class="mt-12">
    <h3 class="font-medium">
      Contact
    </h3>

    <div class="mt-4 flex flex-col items-start gap-2 text-muted">
      <a
        href="mailto:ganeswaradande@gmail.com"
        class="text-muted underline underline-offset-4 hover:opacity-80 transition-opacity"
      >
        ganeswaradande@gmail.com
      </a>
    
      <a
        href="https://github.com/thet1nk3r3r"
        target="_blank"
        class="text-muted underline underline-offset-4 hover:opacity-80 transition-opacity"
      >
        GitHub
      </a>
    
      <a
        href="https://www.linkedin.com/in/ganeswaradande"
        target="_blank"
        class="text-muted underline underline-offset-4 hover:opacity-80 transition-opacity"
      >
        LinkedIn
      </a>
    
      <a
        href="https://drive.google.com/file/d/1jXlnRhJAPX8wJFMStaJZZyOl66y4Ylb3/view?usp=sharing"
        class="text-muted underline underline-offset-4 hover:opacity-80 transition-opacity"
      >
        Resume
      </a>
    </div>
  </section>
</BaseLayout>