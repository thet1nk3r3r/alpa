---
import BaseLayout from "../layouts/BaseLayout.astro";
import { education } from "../content/education";
---

<BaseLayout>
  <Fragment slot="title">Education</Fragment>

  <section>
    <h2 class="text-lg font-medium">Education</h2>

    <ul class="mt-10 space-y-12">
      {education.map((item) => (
        <li>
          <h3 class="text-base font-medium">
            {item.degree}
          </h3>

          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
            {item.institution} · {item.location}
            {(item.start || item.year) && " · "}
            {item.start && item.end && `${item.start} – ${item.end}`}
            {item.year && item.year}
          </p>

          {(item.gpa || item.score) && (
            <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
              {item.gpa && `GPA: ${item.gpa}`}
              {item.score && `Score: ${item.score}`}
            </p>
          )}

          {item.description && (
            <p class="mt-3 text-neutral-600 dark:text-neutral-400 leading-relaxed">
              {item.description}
            </p>
          )}
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>