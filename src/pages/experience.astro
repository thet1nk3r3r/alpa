---
import { experience } from "../content/experience";
import BaseLayout from "../layouts/BaseLayout.astro";

---

<BaseLayout>
  <Fragment slot="title">Experience</Fragment>

  <section>
    <h2 class="text-lg font-medium">Work Experience</h2>

    <ul class="mt-10 space-y-12">
      {experience.map((job) => (
        <li>
          <h3 class="text-base font-medium">
            {job.role} · {job.organization}
          </h3>

          <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
            {job.location} · {job.type} · {job.start} – {job.end}
          </p>

          <p class="mt-3 text-neutral-600 dark:text-neutral-400 leading-relaxed">
            {job.description}
          </p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>