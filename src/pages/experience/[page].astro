---
import { experience } from '../../content/experience';
import BaseLayout from '../../layouts/BaseLayout.astro';



const ITEMS_PER_PAGE = 5;

export async function getStaticPaths() {
  const ITEMS_PER_PAGE = 5;
  const totalPages = Math.ceil(experience.length / ITEMS_PER_PAGE);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: (i + 1).toString() }
  }));
}

const page = parseInt(Astro.params.page);
const start = (page - 1) * ITEMS_PER_PAGE;
const end = start + ITEMS_PER_PAGE;

const paginatedItems = experience.slice(start, end);
const totalPages = Math.ceil(experience.length / ITEMS_PER_PAGE);
---
<BaseLayout>
  <section>
    <h1 class="text-2xl font-semibold mb-10">
      Work Experience
    </h1>

    <div class="space-y-10">
      {paginatedItems.map((exp) => (
        <article class="border-l-2 pl-5 border-theme">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
            <div>
              <h2 class="text-lg font-medium">
                {exp.role}
              </h2>

              <p class="text-sm text-muted mt-1">
                {exp.organization}
              </p>

              <p class="text-xs text-muted mt-1">
                {exp.location} · {exp.type}
              </p>
            </div>

            <span class="text-sm text-muted whitespace-nowrap">
              {exp.start} — {exp.end}
            </span>
          </div>

          <p class="mt-3 leading-relaxed text-muted">
            {exp.description}
          </p>
        </article>
      ))}
    </div>

    <nav class="flex justify-between mt-12">
      {page > 1 ? (
        <a
          href={`/experience/${page - 1}`}
          class="text-accent hover:opacity-80 transition-opacity"
        >
          ← Previous
        </a>
      ) : (
        <div />
      )}

      {page < totalPages && (
        <a
          href={`/experience/${page + 1}`}
          class="text-accent hover:opacity-80 transition-opacity"
        >
          Next →
        </a>
      )}
    </nav>
  </section>
</BaseLayout>